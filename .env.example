# Upstash Redis credentials (Vercel's official storage option for free tier).
# Get these from Vercel dashboard → Storage → Marketplace → Upstash Redis.
# When you connect the integration to a project, these env vars auto-populate.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Anthropic API key — required for the "Generate next batch" feature.
# Get one at https://console.anthropic.com/settings/keys
# Add it in Vercel → Project Settings → Environment Variables.
ANTHROPIC_API_KEY=

# Legacy KV_* names also work — leave these unset unless you're using the
# older (deprecated) @vercel/kv integration on an existing project.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
